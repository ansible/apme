{
  "private": true,
  "type": "module",
  "workspaces": [
    "shared",
    "standalone",
    "backstage-plugin/plugins/*"
  ],
  "scripts": {
    "build:shared": "pnpm --filter @apme/ui-shared build",
    "build:standalone": "pnpm --filter @apme/standalone build",
    "dev:standalone": "pnpm --filter @apme/standalone dev",
    "lint": "eslint shared/src/ standalone/src/",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@patternfly/react-core": "^6.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "jsdom": "^26.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=9"
  }
}
